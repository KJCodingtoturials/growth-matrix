            'Seniors & mentors bug fixing support group',
            'Completion certificate from GMD Academy'
          ]
        },
        'digital-marketing': {
          title: 'Digital Marketing Specialist',
          tagline: 'August batch special program. Build business growth strategies, optimize ads, and capture target markets.',
          fee: 'Rs. 1000',
          timing: 'Alternate Days, 40 to 50 minutes duration',
          starts: 'August 2026 (Batch 2)',
          badgeColor: 'badge-blue',
          description: 'Businesses aur brands ki growth, search engine algorithms optimization, aur target lead generation ka premium course.',
          syllabi: [
            'Week 1: Fundamentals of Marketing, Audience mapping, competitor profiling.',
            'Week 2: Complete SEO (Keyword targeting, Search Console, Technical audits, backlink profiling).',
            'Week 3: Social Media Operations (Meta Ads setup, pixel integration, tracking algorithms).',
            'Week 4: Copywriting formulas, conversion funnels optimization, and marketing analytics.'
          ],
          features: [
            'Alternate Day Live Classes',
            'LMS recordings repository access',
            'Active marketing campaigns live evaluation',
            'Freelancing tips for digital marketers'
          ]
        },
        'shopify-meta': {
          title: 'Shopify Store + Meta Ads Advanced',
          tagline: 'August batch special. Create profitable e-commerce stores and scale them using high-performing social ads.',
          fee: 'Rs. 1000',
          timing: 'Alternate Days, 40 to 50 minutes duration',
          starts: 'August 2026 (Batch 2)',
          badgeColor: 'badge-blue',
          description: 'E-commerce platform creation aur Meta platform par advanced campaigns chalane ka detailed step-by-step roadmap.',
          syllabi: [
            'Week 1: Shopify platform setup, premium layouts design, product hunting, and imports.',
            'Week 2: Application configuration, secure checkouts, delivery APIs setup.',
            'Week 3: Meta Business Manager, Custom Audiences building, Pixel optimization.',
            'Week 4: Budget optimization strategies, ABO/CBO scaling, and tracking margins.'
          ],
          features: [
            'Alternate Day live lectures',
            'Recording links updated within 12 hours',
            'Logistics & local sourcing guidance in Pakistan',
            'Campaign analytics feedback'
          ]
        },
        'ai-course': {
          title: 'Artificial Intelligence (AI) for Everyone',
          tagline: 'August batch. Master generative AI tools, automate workflows, and boost productivity by 10x.',
          fee: 'Rs. 1000',
          timing: 'Alternate Days, 40 to 50 minutes duration',
          starts: 'August 2026 (Batch 2)',
          badgeColor: 'badge-blue',
          description: 'AI tools ko apni daily life me implement karein aur complex manual tasks ko automations ke zariye second me solve karna seekhein.',
          syllabi: [
            'Week 1: Introduction to Generative AI models, Prompt Engineering mechanics.',
            'Week 2: AI Design & Visuals (Midjourney, Leonardo, generative fill workflows).',
            'Week 3: Workflows Automation (Creating integrations using Zapier and Make.com).',
            'Week 4: Video creation with AI models, voice synthesizers, and building custom assistants.'
          ],
          features: [
            'Live practice sessions',
            'Video tutorials repository',
            'Free Prompt lists and custom integrations assets',
            'QA sessions'
          ]
        }
      };

      // Quiz State
      let quizStep = 1;
      let quizAnswers = [];

      // Page Template Renderers
      const templates = {
        home: () => `
          <div class="home-page">
            <!-- Hero Section -->
            <section class="hero container">
              <div class="hero-content">
                <div class="badge badge-gold hero-subtitle">Growth Matrix Digital (Founded 2026)</div>
                <h1 class="hero-title">Future-Proof Your Career With Modern Skills</h1>
                <p class="hero-description">
                  GMD Academy me hum aapko professional programming, marketing, aur AI automations sikhate hain. Hamara maqsad Pakistan ke har bache ko skilled banana hai.
                </p>
                <div class="hero-actions">
                  <a href="#/admission" class="btn btn-gold">
                    Enroll Now (Apply)
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
                  </a>
                  <a href="#/courses" class="btn btn-outline">
                    Browse Courses
                  </a>
                </div>
              </div>
              
              <div class="hero-visual">
                <div class="glow-sphere"></div>
                <div class="hero-card glass glass-gold card-flat animate-float">
                  <div class="badge badge-gold" style="margin-bottom: 16px;">Batch 1 Enrollment Open</div>
                  <h3 style="font-size: 1.25rem; margin-bottom: 12px; color: var(--bg-navy);">AI Web Dev & Vibe Coding</h3>
                  <p style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 20px; line-height: 1.5;">
                    Learn vibe coding & WordPress. Classes start <strong>28 June 2026</strong>. (Note: Next month is course ke baad Digital Marketing Management & Meta Ads ka course bhi shuru hoga, fee Rs. 1000).
                  </p>
                  <div style="display: flex; justify-content: space-between; align-items: center;">
                    <div>
                      <span style="font-size: 0.75rem; color: var(--text-muted); display: block; text-transform: uppercase;">Introductory Fee</span>
                      <span style="font-size: 1.6rem; font-weight: bold; color: var(--primary-accent); font-family: var(--font-tech);">Rs. 300</span>
                    </div>
                    <a href="#/course/ai-web-dev" class="btn btn-gold" style="padding: 8px 16px; border-radius: 4px; font-size: 0.8rem;">
