                </div>
              </div>
            </section>

            <!-- Prominent WhatsApp Group & Channel Alert Banner -->
            <section class="container" style="margin-bottom: 40px;">
              <div class="glass glass-gold" style="padding: 24px; text-align: center; border: 2px solid var(--primary-accent);">
                <span class="badge badge-gold" style="margin-bottom: 12px;">Official Updates</span>
                <h3 style="color: var(--bg-navy); margin-bottom: 10px;">GMD Ka Official WhatsApp Group Aur Channel Join Karein</h3>
                <p style="color: var(--text-secondary); margin-bottom: 20px; font-size: 0.95rem; max-width: 600px; margin-left: auto; margin-right: auto;">
                  Important announcements, courses details, fee structure, batch timings aur free learning updates haasil karne ke liye hamare official WhatsApp groups aur channel ko join karein.
                </p>
                <div style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
