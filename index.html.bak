        dashboard: () => {
          let subContent = '';
          if (activeDashSubPage === 'overview') {
            subContent = `
              <h4 style="margin-bottom: 16px; color: var(--bg-navy);">Active Course Progress</h4>
              <div class="glass" style="padding: 20px; margin-bottom: 20px; border: 1px solid var(--border-light)">
                <div style="display: flex; justify-content: space-between; align-items: center;">
                  <h5 style="font-size: 1rem; color: var(--bg-navy)">AI Web Development & Web Coding</h5>
                  <span class="badge badge-gold">Batch 1</span>
                </div>
                <div style="margin-top: 15px;">
                  <span style="font-size: 0.85rem; color: var(--text-secondary)">Course Complete: 45%</span>
                  <div class="progress-bar"><div class="progress-fill" style="width: 45%"></div></div>
                </div>
              </div>

              <h4 style="margin-bottom: 16px; color: var(--primary-accent);">Upcoming Live Session</h4>
              <div class="glass" style="padding: 20px; border: 1px solid var(--border-light)">
                <p style="font-size: 0.95rem; color: var(--text-primary)">
                  Next Live Class is scheduled on <strong>28 June 2026</strong>.
                </p>
                <div style="display: flex; gap: 15px; margin-top: 15px;">
                  <span class="badge badge-blue">Time: 40-50 Mins</span>
                  <span class="badge badge-gold">Trainer: Abu Khabib Yaseen</span>
                </div>
              </div>
            `;
          } else if (activeDashSubPage === 'lectures') {
            subContent = `
              <h4 style="margin-bottom: 16px; color: var(--bg-navy);">Recorded Lecture Playlists</h4>
              <div style="display: flex; flex-direction: column; gap: 12px;">
                <div class="glass" style="padding: 15px; display: flex; justify-content: space-between; align-items: center; border: 1px solid var(--border-light)">
                  <div>
                    <span style="font-size: 0.75rem; color: var(--primary-accent); font-weight: 700;">LECTURE 1</span>
                    <h5 style="margin-top: 2px;">Introduction to HTML5 & Web Layouts</h5>
                  </div>
                  <button class="btn btn-gold" style="padding: 6px 12px; font-size: 0.75rem; border-radius: 4px;" onclick="alert('Accessing LMS Archive Recording...')">Play</button>
                </div>
                <div class="glass" style="padding: 15px; display: flex; justify-content: space-between; align-items: center; border: 1px solid var(--border-light)">
                  <div>
                    <span style="font-size: 0.75rem; color: var(--primary-accent); font-weight: 700;">LECTURE 2</span>
                    <h5 style="margin-top: 2px;">CSS Styling and Grid Perspective</h5>
                  </div>
                  <button class="btn btn-gold" style="padding: 6px 12px; font-size: 0.75rem; border-radius: 4px;" onclick="alert('Accessing LMS Archive Recording...')">Play</button>
                </div>
                <div class="glass" style="padding: 15px; display: flex; justify-content: space-between; align-items: center; border: 1px solid var(--border-light)">
                  <div>
                    <span style="font-size: 0.75rem; color: var(--primary-accent); font-weight: 700;">LECTURE 3</span>
                    <h5 style="margin-top: 2px;">JavaScript DOM Manipulations basics</h5>
                  </div>
                  <button class="btn btn-gold" style="padding: 6px 12px; font-size: 0.75rem; border-radius: 4px;" onclick="alert('Accessing LMS Archive Recording...')">Play</button>
                </div>
              </div>
            `;
          } else if (activeDashSubPage === 'card') {
            subContent = `
              <h4 style="margin-bottom: 16px; color: var(--bg-navy)">Generate GMD Student ID Card</h4>
              <p style="color: var(--text-secondary); font-size: 0.9rem; margin-bottom: 20px;">
                Enter name to generate mock Student ID card for Batch 1 (Founded 2026).
              </p>
              <div class="form-group" style="max-width: 400px;">
                <input type="text" id="idcard-name-input" class="form-control" placeholder="Student Name" value="Ali Khan" oninput="updateIDCard(this.value)" />
              </div>

              <div class="id-card-wrapper" style="max-width: 380px; margin-top: 20px; text-align: left;">
                <div class="glass glass-blue" style="border: 2px solid var(--bg-navy); border-radius: 12px; overflow: hidden; position: relative; box-shadow: 0 10px 30px rgba(18, 41, 71, 0.12); border-color: var(--primary-accent);">
                  <!-- Gold header strip -->
                  <div style="background: var(--bg-navy); padding: 12px 18px; border-bottom: 3px solid var(--primary-accent); display: flex; justify-content: space-between; align-items: center;">
                    <div style="display: flex; align-items: center; gap: 8px;">
                      <img src="./logo.jpg" alt="Logo" style="height: 26px; width: auto; border-radius: 2px;" onerror="this.style.display='none'">
                      <span style="font-size: 0.72rem; font-weight: 800; color: #ffffff; letter-spacing: 0.05em;">GROWTH MATRIX DIGITAL</span>
                    </div>
                    <span class="badge badge-gold" style="font-size: 0.55rem; padding: 2px 6px; text-transform: uppercase;">MEMBER</span>
                  </div>

                  <!-- Card Body -->
                  <div style="padding: 20px; display: grid; grid-template-columns: 80px 1fr; gap: 15px; align-items: center; position: relative;">
                    <!-- Smart Card Gold Chip Mockup -->
                    <div style="position: absolute; right: 20px; top: 15px; width: 32px; height: 26px; background: linear-gradient(135deg, #ffe066 0%, #d4af37 50%, #aa8c1c 100%); border-radius: 4px; border: 1px solid rgba(0,0,0,0.15); box-shadow: inset 0 1px 0 rgba(255,255,255,0.4); display: grid; grid-template-columns: repeat(3, 1fr); gap: 2px; padding: 2px; box-sizing: border-box;">
                      <div style="border-right: 1px solid rgba(0,0,0,0.1); border-bottom: 1px solid rgba(0,0,0,0.1)"></div>
                      <div style="border-right: 1px solid rgba(0,0,0,0.1); border-bottom: 1px solid rgba(0,0,0,0.1)"></div>
                      <div style="border-bottom: 1px solid rgba(0,0,0,0.1)"></div>
                      <div style="border-right: 1px solid rgba(0,0,0,0.1)"></div>
                      <div style="border-right: 1px solid rgba(0,0,0,0.1)"></div>
                      <div></div>
                    </div>

                    <!-- Photo Box -->
                    <div style="width: 80px; height: 80px; border-radius: 8px; border: 2px solid var(--primary-accent); overflow: hidden; background: var(--bg-tertiary); display: flex; align-items: center; justify-content: center; font-size: 2.2rem; box-shadow: 0 4px 10px rgba(0,0,0,0.05);">
                      👤
                    </div>

                    <!-- Info Box -->
                    <div style="display: flex; flex-direction: column; gap: 4px;">
                      <h5 id="idcard-name" style="font-size: 1.15rem; color: var(--bg-navy); font-weight: 800; margin: 0; line-height: 1.2;">Ali Khan</h5>
                      <p style="font-size: 0.72rem; color: var(--text-muted); font-weight: 600; font-family: var(--font-tech); margin: 0;">REG ID: GMD-2026-8947</p>
                      <p style="font-size: 0.75rem; color: var(--text-secondary); margin: 2px 0 0 0;">
                        Course: <strong style="color: var(--bg-navy);">AI Web Development</strong>
                      </p>
                      <p style="font-size: 0.7rem; color: var(--primary-accent); font-weight: 700; text-transform: uppercase; letter-spacing: 0.05em; display: flex; align-items: center; gap: 4px; margin: 0;">
                        ● Batch 1 Student
                      </p>
                    </div>
                  </div>

                  <!-- Footer / Barcode -->
                  <div style="background: var(--bg-secondary); padding: 12px 20px; border-top: 1px solid var(--border-light); display: flex; justify-content: space-between; align-items: center;">
                    <!-- CSS Barcode -->
                    <div style="display: flex; flex-direction: column; gap: 2px;">
                      <div style="display: flex; align-items: stretch; height: 20px; width: 120px;">
                        <div style="width: 2px; background: #000; margin-right: 1px;"></div>
                        <div style="width: 1px; background: #000; margin-right: 2px;"></div>
                        <div style="width: 3px; background: #000; margin-right: 1px;"></div>
                        <div style="width: 1px; background: #000; margin-right: 1px;"></div>
                        <div style="width: 2px; background: #000; margin-right: 2px;"></div>
                        <div style="width: 4px; background: #000; margin-right: 1px;"></div>
                        <div style="width: 1px; background: #000; margin-right: 1px;"></div>
                        <div style="width: 3px; background: #000; margin-right: 2px;"></div>
                        <div style="width: 2px; background: #000; margin-right: 1px;"></div>
                        <div style="width: 1px; background: #000; margin-right: 1px;"></div>
                        <div style="width: 3px; background: #000; margin-right: 1px;"></div>
                        <div style="width: 1px; background: #000; margin-right: 2px;"></div>
                        <div style="width: 2px; background: #000; margin-right: 1px;"></div>
                        <div style="width: 4px; background: #000;"></div>
                      </div>
                      <span style="font-size: 0.55rem; font-family: monospace; color: var(--text-muted); text-align: center;">*GMD-2026-8947*</span>
                    </div>
                    
                    <div style="text-align: right;">
                      <span style="font-size: 0.55rem; color: var(--text-muted); display: block; text-transform: uppercase;">Issue Year</span>
                      <span style="font-size: 0.72rem; font-weight: 800; color: var(--bg-navy);">2026</span>
                    </div>
                  </div>
                </div>
              </div>
            `;
          }

          return `
            <div class="dashboard-page container section-padding">
              <div style="text-align: center; margin-bottom: 40px;">
                <div class="badge badge-blue" style="margin-bottom: 12px;">Student Panel</div>
                <h1>Mock Student Dashboard</h1>
              </div>

              <div class="dash-grid">
                <div>
                  <ul class="dash-menu">
                    <li class="${activeDashSubPage === 'overview' ? 'active' : ''}" onclick="switchDashTab('overview')">Overview</li>
                    <li class="${activeDashSubPage === 'lectures' ? 'active' : ''}" onclick="switchDashTab('lectures')">Lectures archive</li>
                    <li class="${activeDashSubPage === 'card' ? 'active' : ''}" onclick="switchDashTab('card')">Student ID Card</li>
                  </ul>
                </div>
                <div>
                  ${subContent}
                </div>
              </div>
            </div>
          `;
        },
        reviews: () => `
          <div class="reviews-page container section-padding">
            <div style="text-align: center; margin-bottom: 50px;">
              <div class="badge badge-gold" style="margin-bottom: 12px;">Reviews</div>
              <h1>Success Stories</h1>
              <p style="color: var(--text-secondary); max-width: 600px; margin: 10px auto 0 auto;">
                Read what our students say about Growth Matrix Digital (Founded 2026).
              </p>
            </div>

            <div class="grid-3" style="margin-bottom: 40px;">
              <div class="glass card-flat" style="padding: 24px;">
                <div style="color: var(--primary-accent);">★★★★★</div>
                <p style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 12px; line-height: 1.6;">
                  "Maine AI Web Development course join kiya tha. Class timings (40-50 min) bilkul perfect hain aur recordings se revision boht easy ho jati hai."
                </p>
                <h5 style="margin-top: 16px; color: var(--bg-navy);">- Nabeel Malik (Rawalpindi)</h5>
              </div>

              <div class="glass card-flat" style="padding: 24px;">
                <div style="color: var(--primary-accent);">★★★★★</div>
                <p style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 12px; line-height: 1.6;">
                  "Shopify store setup aur custom Meta Ads targeting seekhne ke baad maine local dropshipping start ki. GMD is outstanding platform in Pakistan."
                </p>
                <h5 style="margin-top: 16px; color: var(--bg-navy);">- Zainab Fatima (Sargodha)</h5>
              </div>

              <div class="glass card-flat" style="padding: 24px;">
                <div style="color: var(--primary-accent);">★★★★★</div>
                <p style="color: var(--text-secondary); font-size: 0.9rem; margin-top: 12px; line-height: 1.6;">
                  "GMD team ka response support group me boht fast hai. Fee (Rs. 300) to na hone ke barabar hai. Highly recommended!"
                </p>
                <h5 style="margin-top: 16px; color: var(--bg-navy);">- Haris Jameel (Multan)</h5>
              </div>
            </div>
          </div>
        `,
        syllabus: () => `
          <div class="syllabus-page container section-padding">
            <div style="text-align: center; margin-bottom: 50px;">
              <div class="badge badge-gold" style="margin-bottom: 12px;">Course Syllabi</div>
              <h1>Download Detailed Course PDF</h1>
              <p style="color: var(--text-secondary); max-width: 600px; margin: 10px auto 0 auto;">
                Syllabi guidelines check karein aur details download file request send karein.
              </p>
            </div>

            <div class="grid-2">
              <div class="glass card-flat" style="padding: 25px;">
                <h3 style="font-size: 1.2rem; color: var(--bg-navy); margin-bottom: 10px;">AI Web Development Syllabus</h3>
                <p style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 20px;">
                  Includes HTML5, CSS Grid, Advanced JavaScript and AI integrations.
                </p>
                <a href="https://wa.me/923255224480?text=I%20want%20AI%20Web%20Dev%20Syllabus%20PDF" target="_blank" class="btn btn-gold" style="font-size: 0.75rem; padding: 8px 16px; border-radius: 4px;">Get PDF via WhatsApp</a>
              </div>

              <div class="glass card-flat" style="padding: 25px;">
                <h3 style="font-size: 1.2rem; color: var(--bg-navy); margin-bottom: 10px;">Shopify + Meta Ads Syllabus</h3>
                <p style="font-size: 0.9rem; color: var(--text-secondary); margin-bottom: 20px;">
                  Includes Store configurations, Pixel setup and conversion scaling strategies.
                </p>
                <a href="https://wa.me/923255224480?text=I%20want%20Shopify%20Meta%20Syllabus%20PDF" target="_blank" class="btn btn-blue" style="font-size: 0.75rem; padding: 8px 16px; border-radius: 4px;">Get PDF via WhatsApp</a>
              </div>
            </div>
          </div>
        `,
        quiz: () => {
          let stepContent = '';
          if (quizStep === 1) {
            stepContent = `
              <h4 style="margin-bottom: 20px; font-size: 1.15rem; color: var(--bg-navy)">Question 1: Aap ka interest kis field me sabse zyada hai?</h4>
              <button class="quiz-option" onclick="handleQuizAnswer('coding')">A. Web Coding & Building Sites (Coding/Programming)</button>
              <button class="quiz-option" onclick="handleQuizAnswer('marketing')">B. Sales, Ads, and Branding (Marketing/E-commerce)</button>
              <button class="quiz-option" onclick="handleQuizAnswer('ai')">C. AI Automation & Prompts engineering (Tech innovation)</button>
            `;
          } else if (quizStep === 2) {
            stepContent = `
              <h4 style="margin-bottom: 20px; font-size: 1.15rem; color: var(--bg-navy)">Question 2: Aap class study ke liye daily kitna waqt nikal sakte hain?</h4>
              <button class="quiz-option" onclick="handleQuizAnswer('daily')">A. Daily 1 Hour (Regular work schedule)</button>
              <button class="quiz-option" onclick="handleQuizAnswer('alternate')">B. Alternate Days (Flexible work schedule)</button>
            `;
          } else if (quizStep === 3) {
            stepContent = `
              <h4 style="margin-bottom: 20px; font-size: 1.15rem; color: var(--bg-navy)">Question 3: Aap ka background computer technology me kya hai?</h4>
              <button class="quiz-option" onclick="handleQuizAnswer('beginner')">A. Absolute Beginner (Zero coding knowledge)</button>
              <button class="quiz-option" onclick="handleQuizAnswer('basic')">B. Basic knowledge (Know simple commands)</button>
            `;
          } else if (quizStep === 4) {
            // Recommendation logic
            let recommendedCourse = '';
            let detailsPath = '';
            const interest = quizAnswers[0];

            if (interest === 'coding') {
              recommendedCourse = 'AI Web Development & Advanced Web Coding';
              detailsPath = '#/course/ai-web-dev';
            } else if (interest === 'marketing') {
              recommendedCourse = 'Shopify Store + Meta Ads Advanced';
              detailsPath = '#/course/shopify-meta';
            } else {
              recommendedCourse = 'Artificial Intelligence (AI) for Everyone';
              detailsPath = '#/course/ai-course';
            }

            stepContent = `
              <div style="text-align: center; padding: 10px 0;">
                <div style="font-size: 3rem; color: var(--primary-accent); margin-bottom: 12px;">🎯</div>
                <h4 style="font-size: 1.25rem; margin-bottom: 10px; color: var(--bg-navy)">Recommended Course:</h4>
                <h3 style="font-size: 1.4rem; color: var(--bg-navy); margin-bottom: 20px;">${recommendedCourse}</h3>
                <p style="color: var(--text-secondary); font-size: 0.95rem; margin-bottom: 24px;">
                  Aap ke answers ke mutabik ye course aapke liye sabse behtar rahega taake aap online earning start kar sakein.
                </p>
                <div style="display: flex; justify-content: center; gap: 15px;">
                  <a href="${detailsPath}" class="btn btn-gold">Course Details</a>
                  <button class="btn btn-outline" onclick="resetQuiz()">Retake Quiz</button>
                </div>
              </div>
            `;
          }

          return `
            <div class="quiz-page container section-padding">
              <div style="text-align: center; margin-bottom: 40px;">
                <div class="badge badge-gold" style="margin-bottom: 12px;">Interactive Helper</div>
                <h1>Choose Your Career Path</h1>
              </div>

              <div class="glass quiz-card">
                <div style="display: flex; justify-content: space-between; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 16px; font-family: var(--font-tech)">
                  <span>STEP ${quizStep > 4 ? 4 : quizStep} OF 3</span>
                  <span>${quizStep === 4 ? 'COMPLETED' : 'IN PROGRESS'}</span>
                </div>
                ${stepContent}
              </div>
            </div>
          `;
        },
        policies: () => `
          <div class="policies-page container section-padding" style="text-align: left; max-width: 800px;">
            <div style="text-align: center; margin-bottom: 50px;">
              <div class="badge badge-gold" style="margin-bottom: 12px;">Rules</div>
              <h1>Student Policies & Rules</h1>
              <p style="color: var(--text-secondary); font-size: 0.92rem;">
                Growth Matrix Digital Academy (Founded 2026) guidelines.
              </p>
            </div>

            <div class="glass" style="padding: 35px; display: flex; flex-direction: column; gap: 24px; border: 1px solid var(--border-light)">
              <div>
                <h4 style="color: var(--bg-navy); margin-bottom: 8px;">1. Class Attendance & Decorum</h4>
                <p style="color: var(--text-secondary); font-size: 0.92rem; line-height: 1.6;">
                  Students ko regular live classes attend karni chahiye. Har live class 40 se 50 minutes ki hoti hai. Decorum kharab karne par block list me dala ja sakta hai.
                </p>
              </div>

              <div>
                <h4 style="color: var(--bg-navy); margin-bottom: 8px;">2. Support Groups Behavior</h4>
                <p style="color: var(--text-secondary); font-size: 0.92rem; line-height: 1.6;">
                  Dedicated seniors support group me faqat coding/marketing tasks se mutalik questions allowed hain. Spams strictly prohibited hain.
                </p>
              </div>

              <div>
                <h4 style="color: var(--bg-navy); margin-bottom: 8px;">3. Low Fee Policy</h4>
                <p style="color: var(--text-secondary); font-size: 0.92rem; line-height: 1.6;">
                  GMD ki fees market ke mukable me Rs. 300 aur Rs. 1000 intehai kam hain taake Pakistani youth self-reliance training haasil kar sake. Is fee structure me changes updates schedules par shamil hongi.
                </p>
              </div>
            </div>
          </div>
        `
      };

      // Client Router engine
      function renderPage() {
        const hash = window.location.hash || '#/';
        const contentDiv = document.getElementById('app-content');
        
        // Remove active state from all links
        document.querySelectorAll('.nav-links a').forEach(link => link.classList.remove('active'));

        // Close mobile drawer
        document.getElementById('nav-links').classList.remove('open');

        // Scroll to top
        window.scrollTo(0, 0);

        if (hash === '#/' || hash === '') {
          contentDiv.innerHTML = templates.home();
          document.getElementById('nav-home').classList.add('active');
          setTimeout(window.animateCounters, 100);
        } else if (hash === '#/ceo') {
          contentDiv.innerHTML = templates.ceo();
          document.getElementById('nav-ceo').classList.add('active');
        } else if (hash === '#/mission') {
          contentDiv.innerHTML = templates.mission();
          document.getElementById('nav-mission').classList.add('active');
        } else if (hash === '#/courses') {
          contentDiv.innerHTML = templates.courses();
          document.getElementById('nav-courses').classList.add('active');
        } else if (hash.startsWith('#/course/')) {
          const courseId = hash.replace('#/course/', '');
          contentDiv.innerHTML = templates.courseDetail(courseId);
          document.getElementById('nav-courses').classList.add('active');
        } else if (hash === '#/schedule') {
          contentDiv.innerHTML = templates.schedule();
          document.getElementById('nav-schedule').classList.add('active');
        } else if (hash === '#/admission') {
          contentDiv.innerHTML = templates.admission();
        } else if (hash === '#/contact') {
          contentDiv.innerHTML = templates.contact();
          document.getElementById('nav-contact').classList.add('active');
        } else if (hash === '#/dashboard') {
          contentDiv.innerHTML = templates.dashboard();
          document.getElementById('nav-dashboard').classList.add('active');
        } else if (hash === '#/reviews') {
          contentDiv.innerHTML = templates.reviews();
        } else if (hash === '#/syllabus') {
          contentDiv.innerHTML = templates.syllabus();
        } else if (hash === '#/quiz') {
          contentDiv.innerHTML = templates.quiz();
          document.getElementById('nav-quiz').classList.add('active');
        } else if (hash === '#/policies') {
          contentDiv.innerHTML = templates.policies();
        } else {
          // Fallback
          contentDiv.innerHTML = templates.home();
          document.getElementById('nav-home').classList.add('active');
        }
      }

      // Tab switcher helper on Courses page
      window.switchCourseTab = function(tabName) {
        activeCourseTab = tabName;
        renderPage();
      };

      // Dashboard tab switch helper
      window.switchDashTab = function(tabName) {
        activeDashSubPage = tabName;
        renderPage();
      };

      // Dynamic ID Card name sync
      window.updateIDCard = function(val) {
        document.getElementById('idcard-name').textContent = val || 'Ali Khan';
      };

      // Quiz Answer controller
      window.handleQuizAnswer = function(answer) {
        quizAnswers.push(answer);
        quizStep++;
        renderPage();
      };

      window.resetQuiz = function() {
        quizStep = 1;
        quizAnswers = [];
        renderPage();
      };

      // Receipt Preview Handler
      window.previewReceipt = function(event) {
        const file = event.target.files[0];
        const previewContainer = document.getElementById('receipt-preview-container');
        const previewImg = document.getElementById('receipt-preview-img');
        if (!file || !previewContainer || !previewImg) return;

        const reader = new FileReader();
        reader.onload = function(e) {
          previewImg.src = e.target.result;
          previewContainer.style.display = 'block';
        };
        reader.readAsDataURL(file);
      };

      // Form submit handler
      window.handleFormSubmit = function(e) {
        e.preventDefault();
        
        const name = document.getElementById('form-name').value;
        const phone = document.getElementById('form-phone').value;
        const city = document.getElementById('form-city').value;
        const courseVal = document.getElementById('form-course').value;
        const trxId = document.getElementById('form-trx-id').value;
        const receiptInput = document.getElementById('form-receipt');
        const message = document.getElementById('form-message').value;
        const submitBtn = document.getElementById('form-submit-btn');

        if (!name || !phone || !city || !trxId || !receiptInput.files[0]) {
          window.showToast('Meharbani karke saari details aur receipt upload karein.', 'error');
          return;
        }

        // Show loading status on button
        const originalBtnText = submitBtn.innerHTML;
        submitBtn.innerHTML = 'Uploading Receipt... Please Wait ⏳';
        submitBtn.disabled = true;
        window.showToast('Uploading receipt screenshot...', 'info');

        // Prepare upload payload to tmpfiles.org
        const file = receiptInput.files[0];
        const formData = new FormData();
        formData.append('file', file);

        // Define function to generate and redirect
        const proceedRedirect = (receiptLink) => {
          const courseLabels = {
            'ai-web-dev': 'AI Web Development (June Batch - Rs. 300)',
            'digital-marketing': 'Digital Marketing (August Batch - Rs. 1000)',
            'shopify-meta': 'Shopify Store + Meta Ads (August Batch - Rs. 1000)',
            'ai-course': 'Artificial Intelligence (August Batch - Rs. 1000)'
          };

          const text = `Assalamu Alaikum Abu Khabib Yaseen,
Mera naam: *${name}*
WhatsApp number: *${phone}*
City: *${city}*
Course: *${courseLabels[courseVal]}*
Transaction ID: *${trxId}*
Receipt Screenshot URL: ${receiptLink}
Message: ${message || 'None'}`;

          const encodedText = encodeURIComponent(text);
          const primaryNumber = '923255224480'; // 0325 52 24 480
          const whatsappUrl = `https://wa.me/${primaryNumber}?text=${encodedText}`;

          // Reset button
          submitBtn.innerHTML = originalBtnText;
          submitBtn.disabled = false;

          // Redirect to WhatsApp
          window.open(whatsappUrl, '_blank');
          window.showToast('Opening WhatsApp chat...', 'success');

          // Show success status
          const formContainer = document.getElementById('admission-form').parentElement;
          formContainer.innerHTML = `
            <div style="text-align: center; padding: 20px 0;">
              <div style="font-size: 3rem; color: var(--primary-accent); margin-bottom: 16px;">✓</div>
              <h4 style="font-size: 1.2rem; margin-bottom: 10px; color: var(--bg-navy)">Application Submitted!</h4>
              <p style="color: var(--text-secondary); font-size: 0.92rem; margin-bottom: 20px; line-height: 1.6; max-width: 450px; margin-left: auto; margin-right: auto;">
                Aapka admission form aur transaction details WhatsApp ke liye tayyar hain. Agar WhatsApp window open nahi hui to niche button dabakar proceed karein.<br>
                <strong>Zaroori Note:</strong> Meharbani karke chat open hone par wahan apni uploaded screenshot receipt picture bhi attach kar ke send kar dein.
              </p>
              <button class="btn btn-gold" onclick="window.open('${whatsappUrl}', '_blank')" style="margin-bottom: 10px;">
                Re-open WhatsApp Chat
              </button>
            </div>
          `;
        };

        // Upload receipt file using Fetch
        fetch('https://tmpfiles.org/api/v1/upload', {
          method: 'POST',
          body: formData
        })
        .then(response => {
          if (!response.ok) throw new Error('Upload server error');
          return response.json();
        })
        .then(resData => {
          if (resData.status === 'success' && resData.data && resData.data.url) {
            // Replace tmpfiles.org/XXXX/file with tmpfiles.org/dl/XXXX/file for direct link
            const directUrl = resData.data.url.replace('https://tmpfiles.org/', 'https://tmpfiles.org/dl/');
            proceedRedirect(directUrl);
          } else {
            throw new Error('Upload failed');
          }
        })
        .catch(err => {
          console.error(err);
          window.showToast('Receipt upload failed! Proceeding with offline manual attachment...', 'warning');
          // Fallback to offline manual attachment note
          proceedRedirect('[Picture attached manually in WhatsApp chat]');
        });
      };

      // Theme Toggle Logic
      function initTheme() {
        const toggleBtn = document.getElementById('theme-toggle-btn');
        if (!toggleBtn) return;
        
        const currentTheme = localStorage.getItem('theme') || 'light';
        if (currentTheme === 'dark') {
          document.documentElement.classList.add('dark-theme');
          toggleBtn.textContent = '☀️';
        } else {
          document.documentElement.classList.remove('dark-theme');
          toggleBtn.textContent = '🌙';
        }
        
        toggleBtn.addEventListener('click', () => {
          if (document.documentElement.classList.contains('dark-theme')) {
            document.documentElement.classList.remove('dark-theme');
            localStorage.setItem('theme', 'light');
            toggleBtn.textContent = '🌙';
          } else {
            document.documentElement.classList.add('dark-theme');
            localStorage.setItem('theme', 'dark');
            toggleBtn.textContent = '☀️';
          }
        });
      }
      initTheme();

      // Preloader Controller
      function initPreloader() {
        const preloader = document.getElementById('preloader');
        const progressBar = document.getElementById('preloader-bar');
        if (!preloader || !progressBar) return;

        // Step 1: Start filling the progress bar
        setTimeout(() => {
          progressBar.style.width = '100%';
        }, 100);

        // Fallback in case window load event already fired or takes too long
        const fallbackTimeout = setTimeout(() => {
          preloader.classList.add('fade-out');
          document.body.classList.add('loaded');
          setTimeout(() => {
            preloader.style.display = 'none';
          }, 600);
        }, 3000);

        // Step 2: Fade out preloader and reveal content after bar finishes (1.2s transition)
        window.addEventListener('load', () => {
          clearTimeout(fallbackTimeout);
          setTimeout(() => {
            preloader.classList.add('fade-out');
            document.body.classList.add('loaded');
            
            // Clean up preloader element from layout click calculations
            setTimeout(() => {
              preloader.style.display = 'none';
            }, 600);
          }, 1300); // Gives time to see the beautiful loading progress
        });
      }
      initPreloader();

      // Watch for Hash Changes
      window.addEventListener('hashchange', renderPage);

      // Initial Render
      window.addEventListener('load', renderPage);
    </script>
  </body>
</html>
