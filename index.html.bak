                    </a>
                  </div>
                </div>
              </div>
            </section>

            <!-- Stats Section -->
            <section class="section-padding container" style="border-top: 1px solid var(--border-light)">
              <div class="stats-grid">
                <div class="stat-card glass card-flat">
                  <div class="stat-number"><span class="count-up" data-target="100000">0</span>+</div>
                  <div class="stat-label">Youth Mission</div>
